{
  "name": "ai-document-platform",
  "version": "1.0.0",
  "description": "Production-grade AI document platform with DDD, pgvector semantic search, and RAG pipeline",
  "module": "src/app.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/app.ts",
    "start": "bun run src/app.ts",
    "build": "bun build src/app.ts --outdir dist --target bun",
    "build:docs": "bun run scripts/build-docs.ts",
    "worker": "bun run src/worker.ts",
    "test": "bun run test:unit",
    "test:unit": "bun test tests/unit/embedding && bun test tests/unit/search",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "db:migrate": "bunx prisma migrate dev",
    "db:migrate:prod": "bunx prisma migrate deploy",
    "db:generate": "bunx prisma generate",
    "postinstall": "bunx prisma generate",
    "db:seed": "bunx prisma generate && bun run prisma/seed.ts",
    "db:sync-embedding-dim": "bun run scripts/sync-embedding-dimension.ts",
    "db:studio": "bunx prisma studio",
    "lint": "bunx biome check src",
    "lint:fix": "bunx biome check --write src",
    "format": "bunx biome format --write src"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.2",
    "@elysiajs/jwt": "^1.2.2",
    "@elysiajs/swagger": "^1.2.2",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/inference": "^4.13.15",
    "@prisma/client": "^6.8.2",
    "@xenova/transformers": "^2.17.2",
    "bullmq": "^5.53.1",
    "elysia": "^1.2.25",
    "gpt-tokenizer": "^3.4.0",
    "ioredis": "^5.6.0",
    "mammoth": "^1.12.0",
    "node-html-parser": "^7.1.0",
    "openai": "^6.38.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "bun-types": "latest",
    "prisma": "^6.8.2"
  }
}

{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "AI Document Platform",
    "description": "API collection for bun-server-js AI Document Platform.\n\n**Auth flow**\n1. Run **Auth → Login** (or Register).\n2. The test script saves `accessToken` to collection variables.\n3. All protected requests use `Authorization: Bearer {{accessToken}}` automatically.\n\n**Suggested order**\nLogin → Upload Document → Get Job Status → Search → RAG Retrieval",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection uses Bearer {{accessToken}} — set it via Login or Register"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "jobId",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "admin@gmail.com",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "ryan@123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Public health check (no JWT required)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Public auth endpoints. Login/Register save `accessToken` automatically.",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  if (body.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  }",
                  "  if (body.user?.id) {",
                  "    pm.collectionVariables.set('userId', body.user.id);",
                  "  }",
                  "  pm.test('Token saved', () => {",
                  "    pm.expect(pm.collectionVariables.get('accessToken')).to.be.a('string').and.not.empty;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\",\n  \"displayName\": \"New User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  }",
                  "  if (body.user?.id) {",
                  "    pm.collectionVariables.set('userId', body.user.id);",
                  "  }",
                  "  pm.test('Login OK — token saved', () => {",
                  "    pm.expect(pm.collectionVariables.get('accessToken')).to.be.a('string').and.not.empty;",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Sign in with seed admin (default from .env.example). On success, `accessToken` is stored for all protected APIs."
          },
          "response": []
        },
        {
          "name": "Get Me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{accessToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Verify JWT — run after Login."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Upload Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if ([200, 201, 202].includes(pm.response.code)) {",
                  "  const body = pm.response.json();",
                  "  const docId = body.document?.id || body.documentId;",
                  "  if (docId) pm.collectionVariables.set('documentId', docId);",
                  "  if (body.jobId) pm.collectionVariables.set('jobId', body.jobId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Select a PDF, DOCX, TXT, MD, CSV, JSON, or HTML file"
                },
                {
                  "key": "tags",
                  "value": "demo,postman",
                  "type": "text",
                  "disabled": true
                },
                {
                  "key": "chunkingStrategy",
                  "value": "recursive",
                  "type": "text",
                  "disabled": true
                },
                {
                  "key": "chunkSize",
                  "value": "512",
                  "type": "text",
                  "disabled": true
                },
                {
                  "key": "chunkOverlap",
                  "value": "50",
                  "type": "text",
                  "disabled": true
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/documents/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "documents", "upload"]
            },
            "description": "multipart/form-data — pick a file in the Body tab. Saves `documentId` and `jobId` on success."
          },
          "response": []
        },
        {
          "name": "List Documents",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const first = body.data?.[0];",
                  "  if (first?.id && !pm.collectionVariables.get('documentId')) {",
                  "    pm.collectionVariables.set('documentId', first.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/documents?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "documents"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "indexed", "disabled": true },
                { "key": "tags", "value": "finance", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Document by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "documents", "{{documentId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get Document Chunks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}/chunks?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "documents", "{{documentId}}", "chunks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Reindex Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chunkingStrategy\": \"recursive\",\n  \"chunkSize\": 512,\n  \"chunkOverlap\": 50\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}/reindex",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "documents", "{{documentId}}", "reindex"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/documents/{{documentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "documents", "{{documentId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Get Job Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/jobs/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "jobs", "{{jobId}}"]
            },
            "description": "Poll after upload until status is completed/failed."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search (semantic / hybrid / keyword)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What are the main topics in the document?\",\n  \"searchType\": \"hybrid\",\n  \"topK\": 10,\n  \"similarityThreshold\": 0.7,\n  \"filters\": {\n    \"documentIds\": [\"{{documentId}}\"]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/search",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "search"]
            }
          },
          "response": []
        },
        {
          "name": "RAG Retrieval",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Summarize the key points\",\n  \"topK\": 5,\n  \"maxTokens\": 2048,\n  \"similarityThreshold\": 0.65,\n  \"filters\": {\n    \"documentIds\": [\"{{documentId}}\"]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/search/retrieval",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "search", "retrieval"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Activity Logs",
      "item": [
        {
          "name": "List Activity Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/activity-logs?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "activity-logs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "domain", "value": "DOCUMENT", "disabled": true },
                { "key": "entityId", "value": "{{documentId}}", "disabled": true },
                { "key": "action", "value": "CREATED", "disabled": true }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}

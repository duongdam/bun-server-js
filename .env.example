# Environment Variables — AI Document Platform
# Copy this file to .env and fill in the values

# ─── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:ryan123@localhost:5432/ai_docs?schema=public"

# ─── Redis (BullMQ) ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Authentication ──────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET="change-me-in-production-use-a-long-random-secret"
JWT_EXPIRES_IN="7d"
# Set AUTH_DEV_BYPASS=true only for local dev without login (not recommended once auth is enabled)
AUTH_DEV_BYPASS="false"

# Seed admin user (used by bun run db:seed)
SEED_ADMIN_EMAIL="admin@gmail.com"
SEED_ADMIN_PASSWORD="ryan@123"

# ─── Embedding Provider ───────────────────────────────────
# Options: openai | huggingface | local
EMBEDDING_PROVIDER="huggingface"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"
# Options: text-embedding-3-small | text-embedding-3-large | text-embedding-ada-002
EMBEDDING_MODEL="text-embedding-3-small"

# HuggingFace (used when EMBEDDING_PROVIDER=huggingface)
HUGGINGFACE_API_KEY="hf-your-huggingface-api-key"
HUGGINGFACE_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# Local (used when EMBEDDING_PROVIDER=local — no API key required)
LOCAL_MODEL="Xenova/all-MiniLM-L6-v2"

# ─── File Upload ──────────────────────────────────────────
# Maximum file upload size in bytes (default: 104857600 = 100MB)
MAX_FILE_SIZE=104857600

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Background Workers ───────────────────────────────────
WORKER_CONCURRENCY=4
JOB_MAX_RETRIES=3

# ─── Package Version ──────────────────────────────────────
NPM_PACKAGE_VERSION=1.0.0
